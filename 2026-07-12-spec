3.1 Shared TypeScript Types
Location: shared/types.ts
/**
 * Shared Type Definitions
 * 
 * Single source of truth across CLI, Dashboard, and SDK.
 * If a type is updated here, all surfaces must compile.
 */

/**
 * Feature flag configuration
 */
export interface FlagConfig {
  id: string;                          // Unique identifier (e.g., 'dark-mode')
  name: string;                        // Display name (e.g., 'Dark Mode Toggle')
  description?: string;                // Optional explanation
  enabled: boolean;                    // Is flag active?
  rollout_percentage: number;          // 0–100% of users receive flag
  audience_rules?: AudienceRule[];     // Optional targeting rules
  environment: 'development' | 'staging' | 'production';
  created_at: string;                  // ISO 8601 timestamp
  updated_at: string;                  // ISO 8601 timestamp
}

/**
 * Targeting rule — who gets the flag
 */
export interface AudienceRule {
  type: 'segment' | 'country' | 'email_domain' | 'user_id';
  operator: 'equals' | 'not_equals' | 'contains' | 'in_list';
  value: string | string[];
}

/**
 * Simulation request — what to test
 */
export interface SimulationRequest {
  flag_id: string;
  mock_users: MockUser[];              // Sample audience for testing
  environment: 'development' | 'staging' | 'production';
}

/**
 * Sample user for simulation
 */
export interface MockUser {
  user_id: string;
  email?: string;
  country?: string;
  segment?: string;
  attributes?: Record<string, string>;
}

/**
 * Simulation result — predicted outcome
 */
export interface SimulationResult {
  flag_id: string;
  simulation_id: string;
  result: 'all_clear' | 'conflict' | 'warning';
  summary: {
    passed: number;                    // Users who would receive flag
    conflicted: number;                // Users excluded by conflicting rules
    warned: number;                    // Users with partial matches
    total: number;
  };
  decisions: FlagDecision[];           // Per-user breakdown
  exit_code: number;                   // 0=all clear, 1=conflict, 2=warning
  evaluated_at: string;
  total_latency_ms: number;
}

/**
 * Per-user decision in simulation
 */
export interface FlagDecision {
  user_id: string;
  decision: 'receive' | 'exclude' | 'partial';
  matched_rules: string[];             // Which rules applied
  reason: string;                      // Human-readable explanation
  rule_sources: string[];              // Source file locations (for tracing)
}

/**
 * Conflict types between rules
 */
export interface ConflictDetail {
  rule_a: string;
  rule_b: string;
  conflict_type: 'overlap' | 'mutual_exclusion' | 'circular_dependency';
  affected_users: number;
}
