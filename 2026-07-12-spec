import { useState } from 'react';
import { Menu, X } from '@heroicons/react/solid';

const DESIGN_PRINCIPLES = [
  {
    id: 'scannable',
    title: 'Output scannable in 3 seconds',
    description: 'Top-level verdict visible before scrolling. Users should understand the result instantly.',
    example: 'Summary card at top of dashboard with counts for received/excluded/partial',
  },
  {
    id: 'functional-colors',
    title: 'Colors functional, not decorative',
    description: 'Green = receive, Red = exclude, Yellow = partial. No accent colors for branding.',
    example: 'Same colors used in CLI (ANSI), Dashboard (Tailwind), and SDK (data)',
  },
  {
    id: 'exit-codes',
    title: 'Exit codes are the real product',
    description: 'Machines depend on numeric codes. Humans read text. Both served.',
    example: 'Exit 0 = all clear, 1 = conflict, 2 = warning',
  },
  {
    id: 'suggestions',
    title: 'Suggestions beat diagnoses',
    description: '"Did you mean X?" not "Error: invalid input"',
    example: 'Flag ID validation suggests "dark-mode" when user types "DarkMode"',
  },
  {
    id: 'consistency',
    title: 'Consistency is hardest feature',
    description: 'Same field names, colors, terminology across all surfaces.',
    example: 'rollout_percentage in CLI, Dashboard, SDK — never rolloutPercent or percent_rollout',
  },
  {
    id: 'transparent-reasoning',
    title: 'Transparent reasoning beats black boxes',
    description: 'Users always know why a decision was made.',
    example: 'Decision trace shows which rules matched for each user',
  },
  {
    id: 'role-division',
    title: 'Design for explicit role division',
    description: 'Three surfaces for three audiences (typing, clicking, calling).',
    example: 'CLI for engineers, Dashboard for PMs, SDK for pipelines',
