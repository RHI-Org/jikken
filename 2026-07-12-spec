const assert = require('assert');
const { execSync } = require('child_process');

describe('CLI Simulation', () => {
  describe('Basic Execution', () => {
    it('should output simulation results for valid flag', () => {
      const output = execSync('node index.js simulate --flag dark-mode --rollout 25', {
        encoding: 'utf8',
      });

      assert.match(output, /FLAG SIMULATION RESULT/);
      assert.match(output, /Received/);
    });

    it('should exit with code 0 when all clear', () => {
      try {
        execSync('node index.js simulate --flag dark-mode --rollout 100', {
          encoding: 'utf8',
        });
        assert.ok(true);
      } catch (error) {
        assert.strictEqual(error.status, 0);
      }
    });
  });

  describe('Output Format', () => {
    it('should produce valid JSON with --format json', () => {
      const output = execSync(
        'node index.js simulate --flag dark-mode --format json',
        { encoding: 'utf8' }
      );

      const result = JSON.parse(output);
      assert.ok(result.simulation_id);
      assert.ok(result.decisions instanceof Array);
      assert.ok([0, 1, 2, 3, 4, 5, 6].includes(result.exit_code));
    });

    it('should suppress info messages with --quiet', () => {
      const output = execSync(
        'node index.js simulate --flag dark-mode --quiet',
        { encoding: 'utf8' }
      );

      assert.ok(!output.includes('DECISION TRACE'));
    });
  });

  describe('Error Handling', () => {
    it('should error when flag ID has invalid characters', () => {
      try {
        execSync('node index.js simulate --flag "Dark Mode!"', {
          encoding: 'utf8',
          stdio: 'pipe',
        });
        assert.fail('Should have exited with error');
      } catch (error) {
        assert.match(error.stderr, /Invalid flag ID/i);
        assert.strictEqual(error.status, 3);
      }
    });

    it('should suggest correct name when typo detected', () => {
      try {
        execSync('node index.js simulate --flag "DarkMode"', {
          encoding: 'utf8',
          stdio: 'pipe',
        });
        assert.fail('Should have exited with error');
      } catch (error) {
        assert.match(error.stderr, /dark-mode/i);
        assert.match(error.stderr, /Did you mean/i);
      }
    });

    it('should error on invalid rollout percentage', () => {
      try {
        execSync('node index.js simulate --flag dark-mode --rollout 150', {
          encoding: 'utf8',
          stdio: 'pipe',
        });
        assert.fail('Should have exited with error');
      } catch (error) {
        assert.match(error.stderr, /Invalid rollout/i);
        assert.strictEqual(error.status, 3);
      }
    });
  });
});
