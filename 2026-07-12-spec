CI/CD Pipeline Integration
import { FlagClient } from '@flagsim/sdk';

const client = new FlagClient({
  apiKey: process.env.FLAG_API_KEY!,
});

async function validateBeforeDeploy() {
  try {
    const result = await client.simulate({
      flag_id: 'dark-mode',
      mock_users: mockUsers,
      environment: 'production',
    });

    // Machine makes the decision
    if (result.exit_code === 1) {
      console.error(`Deploy halted: ${result.summary.conflicted} conflicts detected`);
      process.exit(1);
    }

    // Warnings continue but alert
    if (result.exit_code === 2) {
      console.warn(`Proceeding with ${result.summary.warned} partial matches`);
    }

    // Safe to deploy
    console.log('Flag validated successfully');
  } catch (error) {
    if (error.isRetryable?.()) {
      console.log(`Retrying in ${error.getRetryDelay(1)}ms...`);
    } else {
      console.error(`Pipeline failed: ${error.message}`);
      if (error.getFirstSuggestion?.()) {
        console.error(`Suggestion: ${error.getFirstSuggestion()}`);
      }
      process.exit(1);
    }
  }
}
