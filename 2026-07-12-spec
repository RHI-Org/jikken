/**
 * Export Utility — PDF Generation
 *
 * Generates a report suitable for documentation or stakeholder review.
 *
 * Design Principle: Transparent reasoning — every decision documented.
 */
import jsPDF from 'jspdf';

export function exportToPDF({ title, meta, summary, decisions }) {
  const doc = new jsPDF();

  // Header
  doc.setFontSize(18);
  doc.text(title, 14, 20);

  // Meta info
  doc.setFontSize(12);
  doc.text(`Flag: ${meta.flag_id}`, 14, 30);
  doc.text(`Simulation ID: ${meta.simulation_id}`, 14, 36);
  doc.text(`Evaluated: ${meta.evaluated_at}`, 14, 42);
  doc.text(`Latency: ${meta.total_latency_ms}ms`, 14, 48);

  // Summary
  doc.setFontSize(14);
  doc.text('Summary', 14, 60);
  doc.setFontSize(11);
  doc.text(
    `${summary.passed} Received  |  ${summary.conflicted} Excluded  |  ${summary.warned} Partial  |  ${summary.total} Total`,
    14,
    67
  );

  // Decisions
  let yPos = 80;
  doc.setFontSize(14);
  doc.text('Decision Trace', 14, yPos);
  yPos += 10;
  doc.setFontSize(10);

  decisions.forEach((decision) => {
    if (yPos > 270) {
      doc.addPage();
      yPos = 20;
    }

    const color =
      decision.decision === 'receive'
        ? [0, 128, 0]
        : decision.decision === 'exclude'
        ? [255, 0, 0]
        : [200, 150, 0];

    doc.setTextColor(...color);
    doc.text(`[${decision.decision.toUpperCase()}] ${decision.user_id}`, 14, yPos);
    doc.setTextColor(0, 0, 0);

    yPos += 7;
    doc.text(`  Reason: ${decision.reason.substring(0, 70)}`, 18, yPos);
    yPos += 6;
    doc.text(`  Rules: ${decision.rule_sources.join(', ')}`, 18, yPos);
    yPos += 10;
  });

  // Footer
  doc.setFontSize(8);
  doc.text('Generated by Feature Flag Lifecycle Tool', 14, 290);

  doc.save(`flag-simulation-${meta.flag_id}-${meta.simulation_id}.pdf`);
}
