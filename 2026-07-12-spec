4.2 CLI Entry Point
Location: cli/index.js
#!/usr/bin/env node

/**
 * CLI Entry Point
 *
 * Feature flag lifecycle — simulation and validation commands.
 *
 * Design Principle: Exit codes are the real product.
 * Design Principle: Suggestions beat diagnoses.
 * Design Principle: Validate before you compute.
 */
const { Command } = require('commander');
const { simulateFlag } = require('./services/simulator');
const { formatOutput } = require('./utils/formatters');
const { EXIT_CODES, COLORS } = require('../shared/constants');

const program = new Command();

program
  .name('flagsim')
  .description('Feature flag lifecycle tool — simulate and validate flag configurations')
  .version('1.0.0');

// ─── Simulate Command ───
program
  .command('simulate')
  .description('Run simulation for a feature flag')
  .requiredOption('--flag <id>', 'Flag identifier (e.g., dark-mode)')
  .option('--rollout <percentage>', 'Rollout percentage (0–100)', '100')
  .option('--users <path>', 'Path to mock users JSON file')
  .option('--rules <path>', 'Path to audience rules JSON file')
  .option('--format <type>', 'Output format: text or json', 'text')
  .option('--quiet', 'Suppress info-level messages')
  .action(async (options) => {
    try {
      const flagId = options.flag;
      const rolloutPercentage = parseInt(options.rollout, 10);

      // Validate flag ID pattern
      if (!/^[a-z0-9-]+$/.test(flagId)) {
        console.error(
          `${COLORS.EXCLUDE.ansi}[ERROR]\u001b[0m Invalid flag ID. Use lowercase letters, numbers, and hyphens.`
        );
        console.error(`Did you mean 'dark-mode' instead of '${flagId}'?`);
        process.exit(EXIT_CODES.INVALID_INPUT);
      }

      // Validate rollout range
      if (isNaN(rolloutPercentage) || rolloutPercentage < 0 || rolloutPercentage > 100) {
        console.error(
          `${COLORS.EXCLUDE.ansi}[ERROR]\u001b[0m Invalid rollout percentage. Must be 0–100.`
        );
        process.exit(EXIT_CODES.INVALID_INPUT);
      }

      // Load mock users (or generate defaults)
      let mockUsers = [];
      if (options.users) {
        mockUsers = require(options.users);
      } else {
        mockUsers = generateDefaultMockUsers(100);
      }

      // Run simulation
      const result = await simulateFlag({
        flag_id: flagId,
        rollout_percentage: rolloutPercentage,
        mock_users: mockUsers,
        environment: 'staging',
      });

      // Output formatted result
      const output = formatOutput(result, options.format, options.quiet);
      console.log(output);

      // Set exit code
      process.exit(result.exit_code);

    } catch (error) {
      if (error.message.includes('API connection')) {
        console.error(
          `${COLORS.EXCLUDE.ansi}[ERROR]\u001b[0m Cannot reach simulation service.`
        );
        console.error(`Suggestion: Verify localhost:8080 is running.`);
        process.exit(EXIT_CODES.CONNECTION_FAILURE);
      }

      console.error(`${COLORS.EXCLUDE.ansi}[ERROR]\u001b[0m ${error.message}`);
      if (error.suggestion) {
        console.error(`Suggestion: ${error.suggestion}`);
      }
      process.exit(EXIT_CODES.CONFLICT);
    }
  });

// ─── Validate Command (for CI/CD) ───
program
  .command('validate')
  .description('Validate flag configuration before deployment')
  .requiredOption('--flag <id>', 'Flag identifier')
  .option('--strict', 'Fail on warnings (CI/CD mode)')
  .action(async (options) => {
    try {
      const result = await simulateFlag({
        flag_id: options.flag,
        mock_users: generateDefaultMockUsers(100),
        environment: 'production',
      });

      if (result.exit_code === 1) {
        console.error(
          `${COLORS.EXCLUDE.ansi}[FAIL]\u001b[0m Conflict detected. Deployment halted.`
        );
        process.exit(EXIT_CODES.CONFLICT);
      }

      if (result.exit_code === 2 && options.strict) {
        console.error(
          `${COLORS.EXCLUDE.ansi}[WARN]\u001b[0m Partial matches detected. --strict mode halting.`
        );
        process.exit(EXIT_CODES.WARNING);
      }

      console.log(
        `${COLORS.RECEIVE.ansi}[OK]\u001b[0m Flag validated. Ready for deployment.`
      );
      process.exit(EXIT_CODES.ALL_CLEAR);

    } catch (error) {
      console.error(
        `${COLORS.EXCLUDE.ansi}[ERROR]\u001b[0m Validation failed: ${error.message}`
      );
      process.exit(EXIT_CODES.CONFLICT);
    }
  });

program.parse(process.argv);

// ─── Utility: Generate default mock users ───
function generateDefaultMockUsers(count) {
  const segments = ['early_adopter', 'standard', 'premium', 'enterprise'];
  const countries = ['US', 'CA', 'UK', 'DE', 'FR'];

  return Array.from({ length: count }, (_, i) => ({
    user_id: `user_${String(i).padStart(3, '0')}`,
    email: `user${i}@example.com`,
    segment: segments[i % segments.length],
    country: countries[i % countries.length],
  }));
}
