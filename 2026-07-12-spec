// ─── SDK Demo Tab ───
function SDKDemo() {
  return (
    <div className="space-y-4">
      <h2 className="text-xl font-semibold">SDK (Pipeline Surface)</h2>

      <pre className="bg-gray-900 text-green-400 p-4 rounded overflow-x-auto">
{`import { FlagClient } from '@flagsim/sdk';

const client = new FlagClient({
  apiKey: process.env.FLAG_API_KEY,
  timeoutMs: 5000,
});

async function validateBeforeDeploy() {
  try {
    const result = await client.simulate({
      flag_id: 'dark-mode',
      mock_users: mockUsers,
      environment: 'production',
    });

    // Machine makes the decision
    if (result.exit_code === 1) {
      console.error(\`Deploy halted: \${result.summary.conflicted} conflicts\`);
      process.exit(1);
    }

    // Warnings continue but alert
    if (result.exit_code === 2) {
      console.warn(\`Proceeding with \${result.summary.warned} partial matches\`);
    }

    console.log('Flag validated successfully');

  } catch (error) {
    // Error includes recovery suggestion
    console.error(\`Pipeline failed: \${error.message}\`);
    if (error.getFirstSuggestion?.()) {
      console.error(\`Suggestion: \${error.getFirstSuggestion()}\`);
    }

    // Retryable errors auto-calculate backoff
    if (error.isRetryable?.()) {
      const delay = error.getRetryDelay(1); // 1000ms
      console.log(\`Retrying in \${delay}ms...\`);
    }

    process.exit(1);
  }
}

// Convenience method — no exit code memorization needed
if (await client.isSafeToDeploy({...})) {
  deploy();
}`}
      </pre>

      <div className="text-sm text-gray-600">
        <p><strong>Key UX decisions:</strong></p>
        <ul className="list-disc ml-4 space-y-1">
          <li>Async/await — clean, modern API for consuming code</li>
          <li>AbortController with timeout — no hanging requests</li>
          <li>Error objects include <code>.getFirstSuggestion()</code> — recovery hints for machines</li>
          <li>Built-in retry logic with exponential backoff (<code>.isRetryable()</code>, <code>.getRetryDelay()</code>)</li>
          <li><code>isSafeToDeploy()</code> convenience method — no need to memorize exit codes</li>
          <li>No credentials in error objects — intentional restraint</li>
        </ul>
      </div>
    </div>
  );
}
