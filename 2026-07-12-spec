/**
 * Output Formatters
 *
 * Consistent styling between text and JSON output.
 *
 * Design Principle: Output scannable in 3 seconds.
 * Design Principle: Colors functional, not decorative.
 */
const { COLORS, EXIT_CODES } = require('../../shared/constants');

function formatOutput(result, format = 'text', quiet = false) {
  if (format === 'json') {
    return JSON.stringify(result, null, 2);
  }

  // Text output
  let output = '\n';
  output += `FLAG SIMULATION RESULT\n`;
  output += `${'='.repeat(60)}\n\n`;

  output += `Flag: ${result.flag_id}\n`;
  output += `Evaluated: ${result.evaluated_at}\n\n`;

  // Summary — always visible first
  output += `SUMMARY\n`;
  output += `${'-'.repeat(40)}\n`;
  output += `  Received:  ${COLORS.RECEIVE.ansi}${result.summary.passed}\u001b[0m\n`;
  output += `  Excluded:  ${COLORS.EXCLUDE.ansi}${result.summary.conflicted}\u001b[0m\n`;
  output += `  Partial:   ${COLORS.PARTIAL.ansi}${result.summary.warned}\u001b[0m\n`;
  output += `  Total:     ${result.summary.total}\n\n`;

  // Exit code interpretation
  const exitMessages = {
    [EXIT_CODES.ALL_CLEAR]: 'All checks passed.',
    [EXIT_CODES.CONFLICT]: 'Conflicts detected. Fix before deploying.',
    [EXIT_CODES.WARNING]: 'Partial matches. Proceed with caution.',
    [EXIT_CODES.INVALID_INPUT]: 'Invalid input. Check flag ID and rules.',
    [EXIT_CODES.CONNECTION_FAILURE]: 'Service unavailable. Retry later.',
    [EXIT_CODES.DEPRECATED]: 'Flag uses deprecated config pattern.',
    [EXIT_CODES.QUOTA_EXCEEDED]: 'Rate limit exceeded. Wait and retry.',
  };

  output += `Exit code: ${result.exit_code} — ${exitMessages[result.exit_code]}\n`;

  if (!quiet) {
    output += `\nDECISION TRACE\n`;
    output += `${'-'.repeat(40)}\n`;
    result.decisions.slice(0, 5).forEach((dec) => {
      const color =
        dec.decision === 'receive'
          ? COLORS.RECEIVE
          : dec.decision === 'exclude'
          ? COLORS.EXCLUDE
          : COLORS.PARTIAL;

      output += `  ${color.ansi}[${dec.decision.toUpperCase()}]\u001b[0m ${dec.user_id}\n`;
      output += `    Reason: ${dec.reason}\n`;
    });

    if (result.decisions.length > 5) {
      output += `\n  ... and ${result.decisions.length - 5} more\n`;
    }
  }

  return output;
}

module.exports = { formatOutput };
4.4 Simulator Service
Location: cli/services/simulator.js
/**
 * Simulator Service
 *
 * Evaluates flag configurations against mock users.
 * Determines which users would receive, be excluded, or partially match.
 *
 * Design Principle: Transparent reasoning — every decision explains why.
 */
const { EXIT_CODES } = require('../../shared/constants');

async function simulateFlag(request) {
  const { flag_id, mock_users, environment } = request;

  // Mock evaluation logic (demo only)
  const decisions = mock_users.map((user) => {
    // Example logic — real system would evaluate Cedar-like rules
    const receivesFlag = Math.random() > 0.3;
    const isPartial = Math.random() > 0.8;

    if (isPartial) {
      return {
        user_id: user.user_id,
        decision: 'partial',
        matched_rules: ['segment:partial_match'],
        reason: 'User matches some but not all targeting rules',
        rule_sources: [`flags/${flag_id}.json:12`],
      };
    }

    return {
      user_id: user.user_id,
      decision: receivesFlag ? 'receive' : 'exclude',
      matched_rules: receivesFlag ? ['segment:match'] : ['segment:no_match'],
      reason: receivesFlag
        ? 'User matches audience rules and rollout percentage'
        : 'User excluded by audience rule or rollout percentage',
      rule_sources: [`flags/${flag_id}.json:${receivesFlag ? 8 : 14}`],
    };
  });

  const summary = {
    passed: decisions.filter((d) => d.decision === 'receive').length,
    conflicted: decisions.filter((d) => d.decision === 'exclude').length,
    warned: decisions.filter((d) => d.decision === 'partial').length,
    total: decisions.length,
  };

  let exitCode = EXIT_CODES.ALL_CLEAR;
  if (summary.conflicted > 0) exitCode = EXIT_CODES.CONFLICT;
  else if (summary.warned > 0) exitCode = EXIT_CODES.WARNING;

  return {
    flag_id,
    simulation_id: `sim_${Date.now()}`,
    result: exitCode === 0 ? 'all_clear' : exitCode === 1 ? 'conflict' : 'warning',
    summary,
    decisions,
    exit_code: exitCode,
    evaluated_at: new Date().toISOString(),
    total_latency_ms: Math.round(Math.random() * 10 * 100) / 100,
  };
}

module.exports = { simulateFlag };
4.5 CLI Exit Code Reference
Exit Code	Constant	Meaning	CI/CD Behavior
0	ALL_CLEAR	All checks passed	Proceed
1	CONFLICT	Rule conflicts detected	Fail deployment
2	WARNING	Non-blocking partial matches	Proceed (unless --strict)
3	INVALID_INPUT	Bad request — fix and retry	Fail (fix and retry)
4	CONNECTION_FAILURE	API unreachable	Retry with backoff
5	DEPRECATED	Flag uses deprecated config	Warn (proceed unless --strict)
6	QUOTA_EXCEEDED	Rate limit hit	Retry after delay

