            const { FlagClient } = require('./sdk/lib/client');

            const client = new FlagClient({
              apiKey: process.env.FLAG_API_KEY,
              baseUrl: 'http://localhost:8080'
            });

            try {
              const result = await client.simulate({
                flag_id: 'dark-mode',
                mock_users: [
                  { user_id: 'user_001', email: 'alice@example.com', country: 'US', segment: 'early_adopter' },
                  { user_id: 'user_002', email: 'bob@example.com', country: 'CA', segment: 'standard' },
                ],
                environment: 'production',
              });

              console.log(`Result: ${result.result}`);
              console.log(`Summary: ${result.summary.passed} received, ${result.summary.conflicted} excluded`);

              if (result.exit_code === 1) {
                core.setFailed(`Conflict detected. ${result.summary.conflicted} users excluded. Deployment halted.`);
                return;
              }

              if (result.exit_code === 2) {
                core.warning(`Partial matches: ${result.summary.warned} users. Proceeding with caution.`);
              }

              console.log('✅ Flag validated successfully');

            } catch (error) {
              core.setFailed(`Simulation failed: ${error.message}`);
              if (error.getFirstSuggestion?.()) {
                console.log(`Suggestion: ${error.getFirstSuggestion()}`);
              }
            }

      - name: Deploy if safe
        if: success()
        run: |
          echo "Deploying flag..."
          echo "Flag deployed!"

      - name: Upload results as artifact
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: simulation-results
          path: sim_*.json
          retention-days: 30
