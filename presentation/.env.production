# Production build values for jk.experienceplus.ai (GitHub Pages deploy).
# These are public client-side values (publishable key) — safe to commit.
# Same org Supabase project as folio — required for the shared
# .experienceplus.ai SSO cookie. Do not point this at a different project.
VITE_SUPABASE_URL=https://bsfngnjvmostukrfhoxx.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_5KQIS44uqlWCBb0rqeMQ2g_IMPUjDbA
# Dashboard is assembled under /dashboard/ on the same origin (see
# scripts/assemble-dist.mjs) so the SSO cookie carries into the iframe.
VITE_DASHBOARD_URL=/dashboard/
