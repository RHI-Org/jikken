{
  "name": "jikken",
  "private": true,
  "version": "1.1.0",
  "type": "module",
  "workspaces": [
    "shared",
    "cli",
    "dashboard",
    "sdk",
    "presentation"
  ],
  "scripts": {
    "present": "npm run dev --workspace presentation",
    "dashboard": "npm run dev --workspace dashboard",
    "cli": "npm run start --workspace cli --",
    "build": "npm run build --workspaces --if-present",
    "build:present": "npm run build --workspace presentation",
    "build:dashboard": "DASHBOARD_BASE=/dashboard/ npm run build --workspace dashboard",
    "vercel-build": "npm run build:present && npm run build:dashboard && node scripts/assemble-dist.mjs",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test:integration": "vitest run tests/integration",
    "lint": "eslint ."
  },
  "devDependencies": {
    "eslint": "^9.15.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.15.0",
    "vitest": "^3.2.6"
  }
}
